<td class="value {% if item.change_pct is none %}flat{% elif item.change_pct > 0 %}up{% elif item.change_pct < 0 %}down{% else %}flat{% endif %}">
  {% if item.change_pct is none %}
    데이터 없음
  {% else %}
    {{ item.close }}
    {% if item.change_pct > 0 %}<span class="arrow">▲</span>{% elif item.change_pct < 0 %}<span class="arrow">▼</span>{% else %}<span class="arrow">-</span>{% endif %}
    {{ '%.2f'|format(item.change_pct|abs) }}%
  {% endif %}
</td>
